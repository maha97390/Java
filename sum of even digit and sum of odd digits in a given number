import java.util.Scanner;
class SumOfEvenOdd
{
	public static void main(String[] args) 
	{
		
		Scanner sc= new Scanner(System.in);
		int num=sc.nextInt();
		int evenSum=0;
		int oddSum=0;
		while(num!=0)
		{

			int a=num%10;
			if(a%2 == 0)
			{
				evenSum=evenSum+1;
			}
			else
			{
				oddSum=oddSum+1;
			}
			num=num/10;
		}
		System.out.println("Sum of Even Digits are:"+evenSum);
		System.out.println("Sum of Odd Digits are:"+oddSum);


	}
}

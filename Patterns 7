import java.util.Scanner;
class  patterns7
{
	public static void main(String[] args) 
	{
		Scanner sc=new Scanner(System.in);
		System.out.println("Enter rows");
		int r=sc.nextInt();
		for(int i=1;i<=r;i++)
		{
			for(int j=1;j<=r;j++)
			{
				if(i>=j)
				{
       				System.out.print(" "+'*'+" ");
				}
				else
				{
					System.out.print(" @ ");
				}
			}
			System.out.println();
		}
	}
}

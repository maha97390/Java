import java.util.Scanner;
class FactorialNumber
{
	public static void main(String[] args) 
	{
		Scanner sc=new Scanner(System.in);
		System.out.println("Enter a number : ");
		int n=sc.nextInt();
		int f=1;
		for(int i=5;i>0 ;i-- )
		{
			f=f*i;
		}
		System.out.println("Factorial of a number : "+f);

	}
}

import java.util.Scanner;
class CapitalLetter 
{
	public static void main(String[] args) 
	{
		Scanner sc=new Scanner(System.in);
		System.out.print("Enter the Alphabet : ");
		char ch=sc.next().charAt(0);
		
		if(ch >= 'a' && ch <= 'z')
		{
			ch=(char)(ch - 32);
		}
		System.out.println("Captital Aplphabet is : "+ch); 
	}
}

import java.util.Scanner;
class Patterns5
{
	public static void main(String[] args)
	{
		Scanner sc=new Scanner(System.in);
		System.out.println("Enter row and col values");
		int r=sc.nextInt();
		int c=sc.nextInt();
		System.out.println("Give a number where to start:");
		int n=sc.nextInt();
		for(int i=1;i<=r;i++)
		{
			for(int j=1;j<=c;j++)
			{
			  System.out.print(" "+n+" ");
			  n=n+1;
			}
			System.out.println();
						
		}
	}
	
	
}

	
				

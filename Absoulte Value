import java.util.Scanner;
class AbsoluteValue 
{
	public static void main(String[] args) 
	{
		Scanner sc=new Scanner(System.in);
		System.out.print("Enter the number : ");
		int num=sc.nextInt();
		System.out.println((num < 0)?(num*(-1)):num);
		
		if(num<0)
		{
			num=num*(-1);
		}
		System.out.println("Absolute value is : "+num);
	}
}
